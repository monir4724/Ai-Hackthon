# Railway environment variables (backend service)
# Set these in Railway dashboard → backend service → Variables

APP_NAME=Rokkhakoboch
APP_ENV=production
APP_KEY=                    # generate locally: php artisan key:generate --show
APP_DEBUG=false
APP_URL=https://your-backend.up.railway.app
FRONTEND_URL=https://innovative-flow-production-c724.up.railway.app

DB_CONNECTION=mysql
# Link MySQL plugin to backend service, then reference plugin vars:
DB_HOST=${{MYSQLHOST}}
DB_PORT=${{MYSQLPORT}}
DB_DATABASE=${{MYSQLDATABASE}}
DB_USERNAME=${{MYSQLUSER}}
DB_PASSWORD=${{MYSQLPASSWORD}}

# AI (required for live analysis — Gemini)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Optional — defaults below match .env.example and work with migrations
SESSION_DRIVER=database
CACHE_STORE=database
QUEUE_CONNECTION=database
LOG_LEVEL=info

# Frontend service (separate Railway service — set at BUILD time)
# VITE_API_URL=https://your-backend.up.railway.app/api
