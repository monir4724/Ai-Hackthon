# Railway environment variables (backend service)
# Set these in Railway dashboard before deploy

APP_NAME=Rokkhakoboch
APP_ENV=production
APP_KEY=           # php artisan key:generate --show
APP_DEBUG=false
APP_URL=https://your-backend.up.railway.app

DB_CONNECTION=mysql
# Use Railway MySQL plugin variables:
DB_HOST=${{MYSQLHOST}}
DB_PORT=${{MYSQLPORT}}
DB_DATABASE=${{MYSQLDATABASE}}
DB_USERNAME=${{MYSQLUSER}}
DB_PASSWORD=${{MYSQLPASSWORD}}

OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# Frontend service (separate Railway service)
# VITE_API_URL=https://your-backend.up.railway.app/api
